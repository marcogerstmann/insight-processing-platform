# -------------------------------------------------------
# AWS credentials / region (used by all local runners)
# -------------------------------------------------------

# Named profile from ~/.aws/credentials or ~/.aws/config (SSO, etc.)
AWS_PROFILE="default"
AWS_REGION="eu-central-1"

# Only needed for Makefile targets (docker push, terraform)
# AWS_ACCOUNT_ID=123456789012

# -------------------------------------------------------
# Application
# -------------------------------------------------------

# Tenant ID assigned to every inbound Readwise event
DEFAULT_TENANT_ID="local-tenant"

# Name of the insights table in DynamoDB
TABLE_NAME_INSIGHTS="ipp-insights"

# SQS queue URLs (created by Terraform; see outputs)
INGEST_QUEUE_URL="https://sqs.eu-central-1.amazonaws.com/123456789012/ipp-dev-ingest-events"
INGEST_DLQ_URL="https://sqs.eu-central-1.amazonaws.com/123456789012/ipp-dev-ingest-events-dlq"

# Cognito user pool backing the REST API's JWT auth (see terraform outputs
# cognito_user_pool_id / cognito_client_id). Required by the rest-local runner.
COGNITO_USER_POOL_ID="eu-central-1_xxxxxxxxx"
COGNITO_CLIENT_ID="your-app-client-id"

# -------------------------------------------------------
# Secrets
# Prefix with "ssm:" to fetch from AWS SSM Parameter Store
# e.g. READWISE_WEBHOOK_SECRET=ssm:/ipp/dev/readwise/webhook_secret
# -------------------------------------------------------

# Readwise webhook shared secret (required for the readwise runner)
READWISE_WEBHOOK_SECRET="your-webhook-secret"

# Anthropic API key (optional — enrichment is skipped when unset)
# ANTHROPIC_API_KEY="sk-ant-..."

# -------------------------------------------------------
# Observability (optional)
# -------------------------------------------------------

# Log level: debug | info | warn | error  (default: info)
# LOG_LEVEL="debug"
