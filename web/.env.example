# Cognito app client backing the REST API's JWT auth. Copy this file to
# web/.env and fill in the real values (.env is gitignored).
#
# The values come from Terraform outputs in terraform/envs/dev:
#   VITE_COGNITO_USER_POOL_ID -> terraform output -raw cognito_user_pool_id
#   VITE_COGNITO_CLIENT_ID    -> terraform output -raw cognito_client_id
#   VITE_REST_API_ENDPOINT    -> terraform output -raw rest_api_endpoint

VITE_AWS_REGION="eu-central-1"
VITE_COGNITO_USER_POOL_ID="eu-central-1_xxxxxxxxx"
VITE_COGNITO_CLIENT_ID="your-app-client-id"
VITE_REST_API_ENDPOINT="https://xxxxxxxxxx.execute-api.eu-central-1.amazonaws.com"
